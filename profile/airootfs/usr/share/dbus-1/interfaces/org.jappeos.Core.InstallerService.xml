<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
                      "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.jappeos.Core.InstallerService">
    <method name="GetLocaleInfo">
      <arg name="locales" type="a{ss}" direction="out"/>
      <arg name="timezones" type="as" direction="out"/>
      <arg name="keyboardLayouts" type="a{s(sa{ss})}" direction="out"/>
    </method>

    <method name="GetStorageInfo">
      <arg name="storageDevices" type="a{s(ta(ssts))}" direction="out"/>
    </method>

    <method name="CreateInstallPlan">
      <arg name="hostname" type="s" direction="in"/>
      <arg name="username" type="s" direction="in"/>
      <arg name="password" type="s" direction="in"/>
      <arg name="timezone" type="s" direction="in"/>
      <arg name="locale" type="s" direction="in"/>
      <arg name="keyboardLayout" type="(ss)" direction="in"/>
      <arg name="disk" type="(sta(ss)a(ta{sv}))" direction="in"/>
      <arg name="installProprietary" type="b" direction="in"/>
      <arg name="installRecommendedDrivers" type="b" direction="in"/>
      <arg name="planId" type="u" direction="out"/>
      <arg name="warnings" type="as" direction="out"/>
    </method>

    <method name="CancelInstallPlan">
      <arg name="plan" type="u" direction="in"/>
    </method>

    <method name="BeginInstallation">
      <arg name="plan" type="u" direction="in"/>
    </method>

    <method name="VerifyUsername">
      <arg name="username" type="s" direction="in"/>
      <arg name="valid" type="b" direction="out"/>
    </method>

    <method name="VerifyHostname">
      <arg name="hostname" type="s" direction="in"/>
      <arg name="valid" type="b" direction="out"/>
    </method>

    <property name="State" type="s" access="read"/>
    <property name="ErrorMessage" type="s" access="read"/>
    <property name="Progress" type="(sds)" access="read"/>
    <property name="CurrentLocale" type="s" access="readwrite"/>
    <property name="CurrentTimezone" type="s" access="readwrite"/>
    <property name="CurrentKeyboardLayout" type="(ss)" access="readwrite"/>
  </interface>
</node>
