<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
                      "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.jappeos.Core.LocaleService">
    <method name="GetLocales">
      <arg name="locales" type="a{ss}" direction="out"/>
    </method>

    <method name="SetLocale">
      <arg name="locale" type="s" direction="in"/>
      <arg name="interactive" type="b" direction="in"/>
    </method>

    <method name="GetKeyboardLayouts">
      <arg name="keyboardLayouts" type="a{ss}" direction="out"/>
    </method>

    <method name="GetKeyboardLayoutVariants">
      <arg name="keyboardLayout" type="s" direction="in"/>
      <arg name="keyboardLayoutVariants" type="as" direction="out"/>
    </method>

    <method name="SetKeyboardLayout">
      <arg name="layout" type="s" direction="in"/>
      <arg name="variant" type="s" direction="in"/>
      <arg name="interactive" type="b" direction="in"/>
    </method>

    <method name="GetTimezones">
      <arg name="timezones" type="as" direction="out"/>
    </method>

    <method name="SetTimezone">
      <arg name="timezone" type="s" direction="in"/>
      <arg name="interactive" type="b" direction="in"/>
    </method>

    <property name="Locale" type="s" access="read"/>
    <property name="KeyboardLayout" type="s" access="read"/>
    <property name="KeyboardLayoutVariant" type="s" access="read"/>
    <property name="Timezone" type="s" access="read"/>
  </interface>
</node>
