<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
                      "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.jappeos.Core.NetworkManagerService">
    <method name="ListDevices">
      <arg name="devices" type="ao" direction="out"/>
    </method>

    <signal name="DeviceAdded">
      <arg name="device" type="o"/>
    </signal>

    <signal name="DeviceRemoved">
      <arg name="device" type="o"/>
    </signal>
  </interface>

  <interface name="org.jappeos.Core.NetworkManagerService.Device">
    <method name="SetEnabled">
      <arg name="enabled" type="b" direction="in"/>
      <doc:doc>
        <doc:description>
          <doc:para>
            Enables or disables the network device.

            On Ethernet devices, this will enable or disable the connection.
            The state of the Ethernet device will be ACTIVATED when enabled and DISCONNECTED when disabled, provided that it has a carrier.
            If the Ethernet device does not have a carrier, its state will be UNAVAILABLE regardless of whether it is enabled or disabled.

            On Wi-Fi devices, this will enable or disable the Wi-Fi radio.
            When enabled, the state of the Wi-Fi device will be ACTIVATED if it is connected to a network, or DISCONNECTED if it is not connected to any network.
            If disabled, the state of the Wi-Fi device will be UNAVAILABLE.
          </doc:para>
        </doc:description>
      </doc:doc>
    </method>

    <property name="Id" type="s" access="read"/>
    <property name="Type" type="s" access="read"/>
    <property name="State" type="s" access="read"/>
    <property name="HwAddress" type="s" access="read"/>
    <property name="Managed" type="b" access="read"/>
    <property name="ActiveConnection" type="o" access="read"/>
  </interface>

  <interface name="org.jappeos.Core.NetworkManagerService.Device.WiFi">
    <method name="Scan"/>

    <method name="Connect">
      <arg name="ssid" type="s" direction="in"/>
      <arg name="security" type="s" direction="in"/>
      <arg name="secret" type="s" direction="in"/>
    </method>

    <method name="Disconnect"/>

    <property name="AccessPoints" type="ao" access="read"/>

    <signal name="ConnectResult">
      <arg name="requestId" type="t"/>
      <arg name="success" type="b"/>
      <arg name="reasonCode" type="s"/>
      <arg name="reasonMessage" type="s"/>
    </signal>

    <signal name="AccessPointAdded">
      <arg name="ap" type="o"/>
    </signal>

    <signal name="AccessPointRemoved">
      <arg name="ap" type="o"/>
    </signal>
  </interface>

  <interface name="org.jappeos.Core.NetworkManagerService.Connection">
    <property name="Id" type="s" access="read"/>
    <property name="Type" type="s" access="read"/>
    <property name="State" type="s" access="read"/>
    <property name="Ip4Address" type="s" access="read"/>
    <property name="Ip6Address" type="s" access="read"/>
    <property name="SignalStrength" type="i" access="read"/>
  </interface>

  <interface name="org.jappeos.Core.NetworkManagerService.AccessPoint">
    <property name="Ssid" type="s" access="read"/>
    <property name="Strength" type="i" access="read"/>
    <property name="Security" type="s" access="read"/>
    <property name="Frequency" type="i" access="read"/>
    <property name="Connected" type="b" access="read"/>
  </interface>
</node>
