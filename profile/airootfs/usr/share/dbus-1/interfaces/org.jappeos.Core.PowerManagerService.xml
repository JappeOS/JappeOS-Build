<!DOCTYPE node PUBLIC "-//freedesktop//DTD D-BUS Object Introspection 1.0//EN"
                      "http://www.freedesktop.org/standards/dbus/1.0/introspect.dtd">
<node>
  <interface name="org.jappeos.Core.PowerManagerService">
    <method name="Shutdown"/>
    <method name="Reboot"/>
    <method name="Suspend"/>

    <method name="ListBatteryDevices">
      <arg name="devices" type="ao" direction="out"/>
    </method>

    <signal name="BatteryDeviceAdded">
      <arg name="device" type="o"/>
    </signal>

    <signal name="BatteryDeviceRemoved">
      <arg name="device" type="o"/>
    </signal>
  </interface>

  <interface name="org.jappeos.Core.PowerManagerService.BatteryDevice">
    <property name="Id" type="s" access="read"/>
    <property name="Type" type="s" access="read"/>
    <property name="PowerSupply" type="b" access="read"/>
    <property name="IsPresent" type="b" access="read"/>
    <property name="State" type="s" access="read"/>
    <property name="ChargePercentage" type="d" access="read"/>
    <property name="TimeToEmpty" type="x" access="read"/>
    <property name="TimeToFull" type="x" access="read"/>
  </interface>
</node>
